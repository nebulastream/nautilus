{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"paths": {
			"vscode": ["./src/lib/vscodeShim.ts"],
			"@nautilus-ir/*": ["../../vscode-nautilus-ir/src/*"]
		}
	},
	"include": ["src", "../../vscode-nautilus-ir/src/parser.ts", "../../vscode-nautilus-ir/src/cfgFromParsedIr.ts"]
}
